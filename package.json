{
  "name": "greek-protocol",
  "version": "0.0.1",
  "private": true,
  "workspaces": {
    "packages": [
      "foundry"
    ]
  },
  "scripts": {
    "account": "yarn workspace @greek/foundry account",
    "account:generate": "yarn workspace @greek/foundry account:generate",
    "account:import": "yarn workspace @greek/foundry account:import",
    "chain": "yarn workspace @greek/foundry chain",
    "compile": "yarn workspace @greek/foundry compile",
    "deploy": "yarn workspace @greek/foundry deploy",
    "format": "cd foundry && forge fmt",
    "lint": "cd foundry && forge fmt --check",
    "postinstall": "husky install",
    "precommit": "lint-staged",
    "test": "yarn workspace @greek/foundry test"
  },
  "lint-staged": {
    "foundry/contracts/**/*.sol": "cd foundry && forge fmt",
    "foundry/test/**/*.sol": "cd foundry && forge fmt"
  },
  "devDependencies": {
    "husky": "~9.1.7",
    "lint-staged": "~16.2.7"
  },
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=20.18.3"
  }
}
