{
  "name": "@greek/market-maker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/direct.ts",
    "start": "tsx src/direct.ts",
    "build": "tsup",
    "direct": "tsx src/direct.ts",
    "bebop": "tsx src/bebop.ts",
    "relay": "tsx src/relay.ts",
    "deribit": "tsx src/deribit.ts",
    "dev:direct": "tsx watch src/direct.ts",
    "dev:bebop": "tsx watch src/bebop.ts",
    "dev:relay": "tsx watch src/relay.ts",
    "dev:deribit": "tsx watch src/deribit.ts",
    "fetch-metadata": "tsx scripts/fetch-metadata.ts",
    "proto": "pbjs -t static-module -w es6 -o src/bebop/proto/pricing_pb.js src/bebop/proto/*.proto && pbts -o src/bebop/proto/pricing_pb.d.ts src/bebop/proto/pricing_pb.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "protobufjs": "^7.5.5",
    "viem": "^2.48.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "eslint": "~9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "protobufjs-cli": "^2.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
