# Template for NextJS environment variables.

# For local development, copy this file, rename it to .env.local, and fill in the values.
# When deploying live, you'll need to store the vars in Vercel/System config.

# If not set, we provide default values (check `scaffold.config.ts`) so developers can start prototyping out of the box,
# but we recommend getting your own API Keys for Production Apps.

# To access the values stored in this env file you can use: process.env.VARIABLENAME
# You'll need to prefix the variables names with NEXT_PUBLIC_ if you want to access them on the client side.
# More info: https://nextjs.org/docs/pages/building-your-application/configuring/environment-variables
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# --- Pricing Stream (WebSocket) ---
# Enable real-time pricing stream (default: true)
NEXT_PUBLIC_ENABLE_PRICING_STREAM=true

# Pricing relay WebSocket URL
# For local development: ws://localhost:3004
# For production: wss://api.greek.finance/pricing (default if unset)
NEXT_PUBLIC_PRICING_WS_URL=wss://api.greek.finance/pricing

# Direct quote server (polled HTTP fallback when Bebop is unavailable)
# Local: http://localhost:3010
# For production: https://api.greek.finance (default if unset)
NEXT_PUBLIC_DIRECT_API_URL=https://api.greek.finance

# RFQ-Direct quote endpoint
# Local: http://localhost:3010
# Production: https://api.greek.finance (default if unset)
NEXT_PUBLIC_RFQ_API_URL=https://api.greek.finance

# RFQ pricing stream WebSocket
# Local: ws://localhost:3011
# Production: wss://api.greek.finance/rfq (default if unset)
NEXT_PUBLIC_RFQ_WS_URL=wss://api.greek.finance/rfq

